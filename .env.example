# MySQL (core ile aynı veritabanı)
NUXT_CVE_DIALECT=mysql
NUXT_CVE_URL=mysql://user:password@127.0.0.1:3306/phishy

# MinIO (Docker S3 uyumlu) — "Rapor oluştur" PDF’ini bucket’a yazar; boş bırakılırsa sadece indirme
# Örnek: docker run -p 9000:9000 -p 9001:9001 -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin minio/minio server /data --console-address ":9001"
NUXT_MINIO_ENDPOINT=http://127.0.0.1:9000
NUXT_MINIO_ACCESS_KEY=user
NUXT_MINIO_SECRET_KEY=password
NUXT_MINIO_BUCKET=cve-reports
# NUXT_MINIO_REGION=us-east-1