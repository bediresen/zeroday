
NUXT_SESSION_SECRET=secret
# HTTP (localhost / iç ağ): false | yalnız HTTPS önünde: true veya kaldırın
# NUXT_SESSION_COOKIE_SECURE=false

NUXT_CVE_DIALECT=postgres
NUXT_CVE_URL=postgres://postgres:postgres@127.0.0.1:5432/zeroday
# docker compose: `docker-compose.yml` app servisi NUXT_CVE_URL ve MinIO uçlarını postgres/minio hostlarına yazar.

NUXT_MINIO_ENDPOINT=http://127.0.0.1:9000
NUXT_MINIO_ACCESS_KEY=user
NUXT_MINIO_SECRET_KEY=password
NUXT_MINIO_BUCKET=cve-reports
# NUXT_MINIO_REGION=us-east-1
NUXT_OPENAI_API_KEY=your-openai-api-key
NUXT_OPENAI_MODEL=gpt-5-nano
NUXT_OPENAI_BASE_URL=https://api.openai.com/v1

# --- docker compose (opsiyonel; postgres + minio konteyner şifreleri) ---
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=zeroday
# POSTGRES_PORT=5432
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=minio12345
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# APP_PORT=3000