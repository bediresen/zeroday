# Oturum (çerez imzası; üretimde en az 32 karakter, rastgele)
NUXT_SESSION_SECRET=change-me-to-a-long-random-string-32chars-min

# Yeni kayıt: kapatmak için false
# NUXT_AUTH_ALLOW_REGISTER=false

# PostgreSQL
NUXT_CVE_DIALECT=postgres
# Şema ile tam URL (önerilen):
NUXT_CVE_URL=postgres://user:password@127.0.0.1:5432/zeroday
# URL kullanmıyorsanız:
# NUXT_CVE_HOST=127.0.0.1
# NUXT_CVE_PORT=5432
# NUXT_CVE_DATABASE=zeroday
# NUXT_CVE_USER=user
# NUXT_CVE_PASSWORD=password

# MinIO (Docker S3 uyumlu) — "Rapor oluştur" PDF’ini bucket’a yazar; boş bırakılırsa sadece indirme
# Örnek: docker run -p 9000:9000 -p 9001:9001 -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin minio/minio server /data --console-address ":9001"
NUXT_MINIO_ENDPOINT=http://127.0.0.1:9000
NUXT_MINIO_ACCESS_KEY=user
NUXT_MINIO_SECRET_KEY=password
NUXT_MINIO_BUCKET=cve-reports
# NUXT_MINIO_REGION=us-east-1

# OpenAI — CVE açıklamaları EN→TR çevirisi (Chat Completions)
# NUXT_OPENAI_API_KEY=sk-...
# NUXT_OPENAI_MODEL=gpt-4o-mini
# İsteğe bağlı: NUXT_OPENAI_BASE_URL=https://api.openai.com/v1